}

<section class="shell-hero">
    <div class="hero-pattern" aria-hidden="true"></div>
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <span class="eyebrow-pill border-white/15 bg-white/10 text-white">Actualités</span>
        <h1 class="mt-6 max-w-4xl font-display text-5xl font-extrabold leading-tight md:text-6xl">Les temps forts de BNA Assurances.</h1>
