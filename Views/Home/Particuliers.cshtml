@{
    ViewData["Title"] = "Particuliers";
}

<section class="shell-hero">
    <div class="hero-pattern" aria-hidden="true"></div>
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <span class="eyebrow-pill border-white/15 bg-white/10 text-white">Particuliers</span>
        <h1 class="mt-6 max-w-4xl font-display text-5xl font-extrabold leading-tight md:text-6xl">Des assurances pensées pour votre quotidien.</h1>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-white/72">Famille, biens, santé, voyage et épargne : une page produit prête à accueillir les offres détaillées.</p>
    </div>
</section>

<section class="bg-bnaWarm py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
            <article class="shell-card">
                <i class="text-bnaGreen" data-lucide="users"></i>
                <h2 class="mt-4 font-display text-xl font-extrabold text-bnaNavy">Ma Famille & Moi</h2>
                <p class="mt-3 text-slate-500">Bloc de présentation pour prévoyance, santé, AWLADI et voyage.</p>
            </article>
            <article class="shell-card">
                <i class="text-bnaGreen" data-lucide="home"></i>
                <h2 class="mt-4 font-display text-xl font-extrabold text-bnaNavy">Mes Biens</h2>
                <p class="mt-3 text-slate-500">Espace réservé aux garanties auto, habitation et équipements.</p>
            </article>
            <article class="shell-card">
                <i class="text-bnaGreen" data-lucide="piggy-bank"></i>
                <h2 class="mt-4 font-display text-xl font-extrabold text-bnaNavy">Mon Argent</h2>
                <p class="mt-3 text-slate-500">Zone prévue pour épargne, retraite et garantie prêt.</p>
            </article>
        </div>
    </div>
</section>
