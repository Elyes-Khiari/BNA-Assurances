@{
    ViewData["Title"] = "Déclarer un Sinistre";
}

<section class="shell-hero">
    <div class="hero-pattern" aria-hidden="true"></div>
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <span class="eyebrow-pill border-white/15 bg-white/10 text-white">Sinistres</span>
        <h1 class="mt-6 max-w-4xl font-display text-5xl font-extrabold leading-tight md:text-6xl">Déclarer un sinistre simplement.</h1>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-white/72">Shell visuel pour une future déclaration guidée et rassurante.</p>
    </div>
</section>

<section class="bg-bnaWarm py-16 lg:py-24">
    <div class="mx-auto grid max-w-7xl gap-6 px-5 lg:grid-cols-[0.8fr_1.2fr] lg:px-8">
        <aside class="shell-card">
            <h2 class="font-display text-2xl font-extrabold text-bnaNavy">Avant de commencer</h2>
            <ul class="mt-5 grid gap-3 text-slate-500">
                <li class="flex gap-2"><i class="mt-1 h-4 w-4 shrink-0 text-bnaGreen" data-lucide="check"></i>Numéro de contrat</li>
                <li class="flex gap-2"><i class="mt-1 h-4 w-4 shrink-0 text-bnaGreen" data-lucide="check"></i>Date et lieu du sinistre</li>
                <li class="flex gap-2"><i class="mt-1 h-4 w-4 shrink-0 text-bnaGreen" data-lucide="check"></i>Photos ou documents utiles</li>
            </ul>
        </aside>
        <div class="placeholder-form p-6">
            <div class="grid gap-4">
                <div class="h-12 rounded-lg bg-white"></div>
                <div class="h-12 rounded-lg bg-white"></div>
                <div class="h-32 rounded-lg bg-white"></div>
                <div class="h-12 rounded-lg bg-white"></div>
            </div>
        </div>
    </div>
</section>
