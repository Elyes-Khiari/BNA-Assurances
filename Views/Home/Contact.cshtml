@{
    ViewData["Title"] = "Contact";
}

<section class="shell-hero">
    <div class="hero-pattern" aria-hidden="true"></div>
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <span class="eyebrow-pill border-white/15 bg-white/10 text-white">Contact</span>
        <h1 class="mt-6 max-w-4xl font-display text-5xl font-extrabold leading-tight md:text-6xl">Parlons de votre protection.</h1>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-white/72">Informations de contact et formulaire visuel pour orienter les demandes.</p>
    </div>
</section>

<section class="bg-bnaWarm py-16 lg:py-24">
    <div class="mx-auto grid max-w-7xl gap-6 px-5 lg:grid-cols-[0.75fr_1.25fr] lg:px-8">
        <aside class="shell-card">
            <h2 class="font-display text-2xl font-extrabold text-bnaNavy">BNA Assurances</h2>
            <div class="mt-6 grid gap-4 text-slate-500">
                <p class="flex gap-3"><i class="h-5 w-5 shrink-0 text-bnaGreen" data-lucide="map-pin"></i>Rue du Lac d'Annecy, Tunis</p>
                <p class="flex gap-3"><i class="h-5 w-5 shrink-0 text-bnaGreen" data-lucide="phone"></i>+216 31 350 000</p>
                <p class="flex gap-3"><i class="h-5 w-5 shrink-0 text-bnaGreen" data-lucide="mail"></i>contact@bna-assurances.com.tn</p>
            </div>
        </aside>
        <div class="placeholder-form p-6">
            <div class="grid gap-4 md:grid-cols-2">
                <div class="h-12 rounded-lg bg-white"></div>
                <div class="h-12 rounded-lg bg-white"></div>
                <div class="h-12 rounded-lg bg-white md:col-span-2"></div>
                <div class="h-32 rounded-lg bg-white md:col-span-2"></div>
            </div>
        </div>
    </div>
</section>
