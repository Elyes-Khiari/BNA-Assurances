@{
    ViewData["Title"] = "Entreprises";
}

<section class="shell-hero">
    <div class="hero-pattern" aria-hidden="true"></div>
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <span class="eyebrow-pill border-white/15 bg-white/10 text-white">Entreprises</span>
        <h1 class="mt-6 max-w-4xl font-display text-5xl font-extrabold leading-tight md:text-6xl">La protection des organisations qui avancent.</h1>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-white/72">Une base visuelle pour détailler les offres multirisques, responsabilité civile, flotte et construction.</p>
    </div>
</section>

<section class="bg-white py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
            <article class="shell-card">
                <i class="text-bnaGreen" data-lucide="building-2"></i>
                <h2 class="mt-4 font-display text-lg font-extrabold text-bnaNavy">Multirisques</h2>
                <p class="mt-3 text-sm leading-7 text-slate-500">Placeholder pour les risques d'exploitation.</p>
            </article>
            <article class="shell-card">
                <i class="text-bnaGreen" data-lucide="scale"></i>
                <h2 class="mt-4 font-display text-lg font-extrabold text-bnaNavy">Responsabilité Civile</h2>
                <p class="mt-3 text-sm leading-7 text-slate-500">Placeholder pour les responsabilités métier.</p>
            </article>
            <article class="shell-card">
                <i class="text-bnaGreen" data-lucide="car-front"></i>
                <h2 class="mt-4 font-display text-lg font-extrabold text-bnaNavy">Flotte Auto</h2>
                <p class="mt-3 text-sm leading-7 text-slate-500">Placeholder pour les véhicules d'entreprise.</p>
            </article>
            <article class="shell-card">
                <i class="text-bnaGreen" data-lucide="hard-hat"></i>
                <h2 class="mt-4 font-display text-lg font-extrabold text-bnaNavy">Construction</h2>
                <p class="mt-3 text-sm leading-7 text-slate-500">Placeholder pour les spécialistes construction.</p>
            </article>
        </div>
    </div>
</section>
