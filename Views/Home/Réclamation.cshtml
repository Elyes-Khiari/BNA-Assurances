@{
    ViewData["Title"] = "Devis Gratuit";
}

<section class="shell-hero">
    <div class="hero-pattern" aria-hidden="true"></div>
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <span class="eyebrow-pill border-white/15 bg-white/10 text-white">Devis gratuit</span>
        <h1 class="mt-6 max-w-4xl font-display text-5xl font-extrabold leading-tight md:text-6xl">Votre estimation en quelques étapes.</h1>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-white/72">Formulaire visuel uniquement, prêt pour une intégration fonctionnelle ultérieure.</p>
    </div>
</section>

<section class="bg-white py-16 lg:py-24">
    <div class="mx-auto max-w-5xl px-5 lg:px-8">
        <div class="mb-8 grid gap-4 md:grid-cols-3">
            <div class="shell-card flex items-center gap-4"><span class="step-dot">1</span><span class="font-bold text-bnaNavy">Profil</span></div>
            <div class="shell-card flex items-center gap-4"><span class="step-dot">2</span><span class="font-bold text-bnaNavy">Besoin</span></div>
            <div class="shell-card flex items-center gap-4"><span class="step-dot">3</span><span class="font-bold text-bnaNavy">Coordonnées</span></div>
        </div>
        <div class="placeholder-form p-6">
            <div class="grid gap-4 md:grid-cols-2">
                <div class="h-12 rounded-lg bg-slate-100"></div>
                <div class="h-12 rounded-lg bg-slate-100"></div>
                <div class="h-12 rounded-lg bg-slate-100"></div>
                <div class="h-12 rounded-lg bg-slate-100"></div>
                <div class="h-28 rounded-lg bg-slate-100 md:col-span-2"></div>
            </div>
        </div>
    </div>
</section>
