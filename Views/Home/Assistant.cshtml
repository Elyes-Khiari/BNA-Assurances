@{
    ViewData["Title"] = "Assistant Virtuel";
    var query = ViewBag.Query as string;
}

<section class="bg-bnaWarm py-20 lg:min-h-[80vh]">
    <div class="mx-auto max-w-4xl px-5 lg:px-8">
        <div class="rounded-3xl bg-white shadow-sm ring-1 ring-black/5 overflow-hidden flex flex-col h-[600px]">
            
            <!-- Header -->
            <div class="bg-bnaNavy px-6 py-4 flex items-center justify-between text-white">
                <div class="flex items-center gap-3">
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10">
                        <i data-lucide="bot" class="h-6 w-6 text-bnaGreen"></i>
                    </div>
                    <div>
                        <h1 class="font-display font-bold text-lg">Assistant BNA</h1>
                        <p class="text-xs text-white/70">Toujours là pour vous aider</p>
                    </div>
                </div>
                <a asp-controller="Home" asp-action="Index" class="text-white/70 hover:text-white transition">
                    <i data-lucide="x" class="h-5 w-5"></i>
                </a>
            </div>

            <!-- Chat Area -->
            <div class="flex-1 overflow-y-auto p-6 bg-slate-50/50" id="chatArea">
                
                <!-- Welcome Message -->
                <div class="flex gap-4 mb-6">
                    <div class="flex-shrink-0">
                        <div class="flex h-10 w-10 items-center justify-center rounded-full bg-bnaNavy text-white">
                            <i data-lucide="bot" class="h-5 w-5"></i>
                        </div>
                    </div>
                    <div class="flex flex-col gap-1 max-w-[80%]">
                        <span class="text-xs font-semibold text-gray-500">Assistant BNA</span>
                        <div class="rounded-2xl rounded-tl-none bg-white p-4 shadow-sm ring-1 ring-black/5 text-gray-700">
                            Bonjour ! Je suis votre assistant virtuel BNA Assurances. Comment puis-je vous accompagner aujourd'hui ?
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(query))
                {
                    <div class="flex gap-4 mb-6 flex-row-reverse">
                        <div class="flex-shrink-0">
                            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-bnaGreen text-white">
                                <i data-lucide="user" class="h-5 w-5"></i>
                            </div>
                        </div>
                        <div class="flex flex-col gap-1 max-w-[80%] items-end">
                            <span class="text-xs font-semibold text-gray-500">Vous</span>
                            <div class="rounded-2xl rounded-tr-none bg-bnaNavy p-4 text-white shadow-sm">
                                @query
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Input Area -->
            <div class="border-t border-gray-100 bg-white p-4">
                <form id="chatForm" class="relative flex items-center">
                    <input type="text" id="chatInput"
                           class="w-full rounded-full border border-gray-200 bg-gray-50 py-3 pl-6 pr-14 text-bnaNavy placeholder:text-gray-400 focus:bg-white focus:outline-none focus:ring-2 focus:ring-bnaGreen/50 transition-all"
                           placeholder="Écrivez un message..."
                           autocomplete="off">

                    <button type="submit"
                            class="absolute right-2 flex h-10 w-10 items-center justify-center rounded-full bg-bnaGreen text-white transition hover:bg-bnaDeepGreen focus:outline-none">
                        <i data-lucide="send" class="h-4 w-4 ml-1"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {

    const chatArea = document.getElementById('chatArea');
    const chatForm = document.getElementById('chatForm');
    const chatInput = document.getElementById('chatInput');

    chatForm.addEventListener('submit', async function (e) {
        e.preventDefault();

        const text = chatInput.value.trim();
        if (!text) return;

        // USER MESSAGE
        const userMsg = document.createElement('div');
        userMsg.className = 'flex gap-4 mb-6 flex-row-reverse';
        userMsg.innerHTML = `
            <div class="flex-shrink-0">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-bnaGreen text-white">
                    <i data-lucide="user" class="h-5 w-5"></i>
                </div>
            </div>
            <div class="flex flex-col gap-1 max-w-[80%] items-end">
                <span class="text-xs font-semibold text-gray-500">Vous</span>
                <div class="rounded-2xl rounded-tr-none bg-bnaNavy p-4 text-white shadow-sm">
                    ${text.replace(/</g, "&lt;").replace(/>/g, "&gt;")}
                </div>
            </div>
        `;
        chatArea.appendChild(userMsg);
        chatInput.value = '';
        chatArea.scrollTop = chatArea.scrollHeight;

        if (window.lucide) window.lucide.createIcons();

        // TYPING
        const botTyping = document.createElement('div');
        botTyping.id = 'tempTyping';
        botTyping.className = 'flex gap-4 mb-6';
        botTyping.innerHTML = `
            <div class="flex-shrink-0">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-bnaNavy text-white">
                    <i data-lucide="bot" class="h-5 w-5"></i>
                </div>
            </div>
            <div class="flex flex-col gap-1 max-w-[80%]">
                <span class="text-xs font-semibold text-gray-500">Assistant</span>
                <div class="rounded-2xl rounded-tl-none bg-white p-4 shadow-sm text-gray-700">
                    typing...
                </div>
            </div>
        `;
        chatArea.appendChild(botTyping);
        chatArea.scrollTop = chatArea.scrollHeight;

        if (window.lucide) window.lucide.createIcons();

        // =========================
        // 🔵 CHANGE AREA START
        // =========================
        const response = await fetch('/api/chat', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ message: text })
        });

        const data = await response.json();
        // =========================
        // 🔵 CHANGE AREA END
        // =========================

        const temp = document.getElementById('tempTyping');

        if (temp) {
            temp.innerHTML = `
                <div class="flex-shrink-0">
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-bnaNavy text-white">
                        <i data-lucide="bot" class="h-5 w-5"></i>
                    </div>
                </div>
                <div class="flex flex-col gap-1 max-w-[80%]">
                    <span class="text-xs font-semibold text-gray-500">Assistant BNA</span>
                    <div class="rounded-2xl rounded-tl-none bg-white p-4 shadow-sm text-gray-700">
                        ${data.reply}
                    </div>
                </div>
            `;

            if (window.lucide) window.lucide.createIcons();
            chatArea.scrollTop = chatArea.scrollHeight;

            temp.removeAttribute('id');
        }
    });
});
</script>
}