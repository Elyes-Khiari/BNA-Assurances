@{
    ViewData["Title"] = "Nos Agences";
}

<section class="shell-hero">
    <div class="hero-pattern" aria-hidden="true"></div>
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <span class="eyebrow-pill border-white/15 bg-white/10 text-white">Nos agences</span>
        <h1 class="mt-6 max-w-4xl font-display text-5xl font-extrabold leading-tight md:text-6xl">Un réseau national à portée de main.</h1>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-white/72">Placeholder de recherche d'agences avec carte et liste de points de contact.</p>
    </div>
</section>

<section class="bg-bnaWarm py-16 lg:py-24">
    <div class="mx-auto grid max-w-7xl gap-6 px-5 lg:grid-cols-[1.3fr_0.7fr] lg:px-8">
        <div class="placeholder-map grid place-items-center p-8 text-center">
            <div>
                <i class="mx-auto h-12 w-12 text-bnaGreen" data-lucide="map"></i>
                <h2 class="mt-4 font-display text-2xl font-extrabold text-bnaNavy">Carte interactive</h2>
                <p class="mt-2 text-slate-500">Zone réservée à la carte des agences.</p>
            </div>
        </div>
        <div class="grid gap-4">
            <article class="shell-card">
                <h2 class="font-display text-lg font-extrabold text-bnaNavy">Agence Tunis Centre</h2>
                <p class="mt-2 text-sm text-slate-500">Adresse, horaires et contact à intégrer.</p>
            </article>
            <article class="shell-card">
                <h2 class="font-display text-lg font-extrabold text-bnaNavy">Agence Sfax</h2>
                <p class="mt-2 text-sm text-slate-500">Adresse, horaires et contact à intégrer.</p>
            </article>
            <article class="shell-card">
                <h2 class="font-display text-lg font-extrabold text-bnaNavy">Agence Sousse</h2>
                <p class="mt-2 text-sm text-slate-500">Adresse, horaires et contact à intégrer.</p>
            </article>
        </div>
    </div>
</section>
