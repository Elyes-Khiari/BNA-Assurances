@model IEnumerable<AssuranceApp.Models.Reclamation>

@{
    ViewData["Title"] = "Suivi de Réclamations";
}

<div class="mx-auto max-w-7xl px-5 py-24 pt-32 lg:px-8">
    <div class="mb-10">
        <h1 class="text-3xl font-display font-bold text-bnaNavy">Mes Réclamations</h1>
        <p class="mt-2 text-slate-600">Suivez l'état d'avancement de vos dossiers en cours.</p>
    </div>

    @if (!Model.Any())
    {
        <div class="rounded-2xl border border-slate-200 bg-white p-12 text-center shadow-sm">
            <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-bnaWarm text-bnaBlue mb-4">
                <i data-lucide="inbox" class="h-8 w-8"></i>
            </div>
            <h3 class="text-lg font-semibold text-bnaNavy">Aucune réclamation en cours</h3>
            <p class="mt-2 text-slate-600">Vous n'avez soumis aucune réclamation pour le moment.</p>
            <div class="mt-6">
                <a asp-action="Create" class="btn btn-primary">Déposer une réclamation</a>
            </div>
        </div>
    }
    else
    {
        <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm text-slate-600">
                    <thead class="bg-slate-50 text-xs uppercase text-slate-500 border-b border-slate-200">
                        <tr>
                            <th scope="col" class="px-6 py-4 font-medium">Référence</th>
                            <th scope="col" class="px-6 py-4 font-medium">Objet</th>
                            <th scope="col" class="px-6 py-4 font-medium">Date</th>
                            <th scope="col" class="px-6 py-4 font-medium">Statut</th>
                            <th scope="col" class="px-6 py-4 font-medium text-right">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var rec in Model)
                        {
                            var statutClass = rec.Statut switch
                            {
                                AssuranceApp.Models.StatutReclamation.Ouverte => "bg-slate-100 text-slate-700",
                                AssuranceApp.Models.StatutReclamation.EnCours => "bg-amber-100 text-amber-800",
                                AssuranceApp.Models.StatutReclamation.Resolue => "bg-emerald-100 text-emerald-800",
                                AssuranceApp.Models.StatutReclamation.Cloturee => "bg-slate-200 text-slate-800",
                                _ => "bg-slate-100 text-slate-700"
                            };

                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="whitespace-nowrap px-6 py-4 font-medium text-bnaNavy">@(string.IsNullOrEmpty(rec.NumeroReclamation) ? $"#{rec.IdReclamation}" : rec.NumeroReclamation)</td>
                                <td class="px-6 py-4">@rec.Objet</td>
                                <td class="px-6 py-4 whitespace-nowrap">@rec.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium @statutClass">
                                        @rec.Statut.ToString()
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-right whitespace-nowrap">
                                    <button type="button" class="text-bnaBlue hover:text-bnaDeepGreen font-medium text-sm inline-flex items-center gap-1" onclick="openModal('modal-@rec.IdReclamation')">
                                        Voir détail <i data-lucide="chevron-right" class="h-4 w-4"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@* Modals for details *@
@foreach (var rec in Model)
{
    var statutClass = rec.Statut switch
    {
        AssuranceApp.Models.StatutReclamation.Ouverte => "bg-slate-100 text-slate-700",
        AssuranceApp.Models.StatutReclamation.EnCours => "bg-amber-100 text-amber-800",
        AssuranceApp.Models.StatutReclamation.Resolue => "bg-emerald-100 text-emerald-800",
        AssuranceApp.Models.StatutReclamation.Cloturee => "bg-slate-200 text-slate-800",
        _ => "bg-slate-100 text-slate-700"
    };

    <div id="modal-@rec.IdReclamation" class="fixed inset-0 z-50 hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <!-- Background backdrop -->
        <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm transition-opacity" onclick="closeModal('modal-@rec.IdReclamation')"></div>

        <div class="fixed inset-0 z-10 w-screen overflow-y-auto">
            <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
                <div class="relative transform overflow-hidden rounded-2xl bg-white text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-2xl">
                    <div class="bg-white px-4 pb-4 pt-5 sm:p-6 sm:pb-4">
                        <div class="sm:flex sm:items-start justify-between">
                            <div class="mt-3 text-center sm:ml-4 sm:mt-0 sm:text-left w-full">
                                <div class="flex items-center justify-between">
                                    <h3 class="text-xl font-semibold leading-6 text-bnaNavy" id="modal-title">
                                        Détail de la réclamation @(string.IsNullOrEmpty(rec.NumeroReclamation) ? $"#{rec.IdReclamation}" : rec.NumeroReclamation)
                                    </h3>
                                    <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium @statutClass">
                                        @rec.Statut.ToString()
                                    </span>
                                </div>
                                
                                <div class="mt-6 space-y-6">
                                    <div>
                                        <h4 class="text-sm font-medium text-slate-500">Objet</h4>
                                        <p class="mt-1 text-base text-slate-900">@rec.Objet</p>
                                    </div>
                                    <div>
                                        <h4 class="text-sm font-medium text-slate-500">Description détaillée</h4>
                                        <div class="mt-1 text-sm text-slate-700 bg-slate-50 p-4 rounded-xl border border-slate-100">
                                            @rec.Description
                                        </div>
                                    </div>
                                    
                                    @if (!string.IsNullOrEmpty(rec.NumeroPolice) || !string.IsNullOrEmpty(rec.NumeroSinistre))
                                    {
                                        <div class="grid grid-cols-2 gap-4">
                                            @if (!string.IsNullOrEmpty(rec.NumeroPolice))
                                            {
                                                <div>
                                                    <h4 class="text-sm font-medium text-slate-500">N° Police / Contrat</h4>
                                                    <p class="mt-1 text-sm text-slate-900">@rec.NumeroPolice</p>
                                                </div>
                                            }
                                            @if (!string.IsNullOrEmpty(rec.NumeroSinistre))
                                            {
                                                <div>
                                                    <h4 class="text-sm font-medium text-slate-500">N° Sinistre</h4>
                                                    <p class="mt-1 text-sm text-slate-900">@rec.NumeroSinistre</p>
                                                </div>
                                            }
                                        </div>
                                    }

                                    @if (!string.IsNullOrEmpty(rec.DemarchesDejaEntreprises))
                                    {
                                        <div>
                                            <h4 class="text-sm font-medium text-slate-500">Démarches déjà entreprises</h4>
                                            <p class="mt-1 text-sm text-slate-900">@rec.DemarchesDejaEntreprises</p>
                                        </div>
                                    }
                                    
                                    @if (!string.IsNullOrEmpty(rec.ResultatSouhaite))
                                    {
                                        <div>
                                            <h4 class="text-sm font-medium text-slate-500">Résultat souhaité</h4>
                                            <p class="mt-1 text-sm text-slate-900">@rec.ResultatSouhaite</p>
                                        </div>
                                    }

                                    @if (!string.IsNullOrEmpty(rec.CommentaireResolution))
                                    {
                                        <div class="mt-6 border-t border-slate-200 pt-6">
                                            <h4 class="text-sm font-medium text-bnaDeepGreen flex items-center gap-2">
                                                <i data-lucide="message-square-check" class="h-4 w-4"></i> Réponse de l'assureur
                                            </h4>
                                            <div class="mt-2 text-sm text-slate-700 bg-emerald-50/50 p-4 rounded-xl border border-emerald-100">
                                                @rec.CommentaireResolution
                                            </div>
                                            @if (rec.DateResolution.HasValue)
                                            {
                                                <p class="mt-2 text-xs text-slate-500 text-right">Le @rec.DateResolution.Value.ToString("dd/MM/yyyy à HH:mm")</p>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="bg-slate-50 px-4 py-3 sm:flex sm:flex-row-reverse sm:px-6">
                        <button type="button" class="btn btn-ghost" onclick="closeModal('modal-@rec.IdReclamation')">Fermer</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        function openModal(id) {
            document.getElementById(id).classList.remove('hidden');
        }
        function closeModal(id) {
            document.getElementById(id).classList.add('hidden');
        }
    </script>
}
