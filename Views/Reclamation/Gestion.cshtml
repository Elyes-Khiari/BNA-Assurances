@model IEnumerable<AssuranceApp.Models.Reclamation>

@{
    ViewData["Title"] = "Gestion des Réclamations";
}

<div class="mx-auto max-w-7xl px-5 py-24 pt-32 lg:px-8">
    <div class="mb-10 flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-3xl font-display font-bold text-bnaNavy">Gestion des Réclamations</h1>
            <p class="mt-2 text-slate-600">Interface administrateur pour le traitement des dossiers.</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 items-center">
            <form method="get" asp-action="Gestion" class="relative flex w-full max-w-sm items-center">
                <input type="text" name="search" value="@ViewData["SearchQuery"]" placeholder="Rechercher par N° de suivi (REC-...)" class="block w-full rounded-lg border-0 py-2 pl-3 pr-10 text-slate-900 ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-bnaGreen sm:text-sm sm:leading-6" />
                <button type="submit" class="absolute inset-y-0 right-0 flex items-center pr-3 text-slate-400 hover:text-bnaGreen">
                    <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
                    </svg>
                </button>
            </form>
            <div class="flex gap-2">
                <span class="inline-flex items-center gap-2 rounded-lg bg-white px-3 py-2 text-sm font-medium shadow-sm border border-slate-200 text-slate-700">
                    <span class="h-2 w-2 rounded-full bg-slate-400"></span> Ouvertes: @Model.Count(r => r.Statut == AssuranceApp.Models.StatutReclamation.Ouverte)
                </span>
                <span class="inline-flex items-center gap-2 rounded-lg bg-white px-3 py-2 text-sm font-medium shadow-sm border border-slate-200 text-amber-700">
                    <span class="h-2 w-2 rounded-full bg-amber-500"></span> En Cours: @Model.Count(r => r.Statut == AssuranceApp.Models.StatutReclamation.EnCours)
                </span>
            </div>
        </div>
    </div>

    <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm text-slate-600">
                <thead class="bg-slate-50 text-xs uppercase text-slate-500 border-b border-slate-200">
                    <tr>
                        <th scope="col" class="px-6 py-4 font-medium">ID / Client</th>
                        <th scope="col" class="px-6 py-4 font-medium">Objet & Date</th>
                        <th scope="col" class="px-6 py-4 font-medium">Statut</th>
                        <th scope="col" class="px-6 py-4 font-medium">Priorité</th>
                        <th scope="col" class="px-6 py-4 font-medium text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var rec in Model)
                    {
                        var statutClass = rec.Statut switch
                        {
                            AssuranceApp.Models.StatutReclamation.Ouverte => "bg-slate-100 text-slate-700 border-slate-200",
                            AssuranceApp.Models.StatutReclamation.EnCours => "bg-amber-100 text-amber-800 border-amber-200",
                            AssuranceApp.Models.StatutReclamation.Resolue => "bg-emerald-100 text-emerald-800 border-emerald-200",
                            AssuranceApp.Models.StatutReclamation.Cloturee => "bg-slate-200 text-slate-800 border-slate-300",
                            _ => "bg-slate-100 text-slate-700"
                        };

                        var priorityClass = rec.Priorite switch
                        {
                            AssuranceApp.Models.PrioriteReclamation.Basse => "text-slate-500",
                            AssuranceApp.Models.PrioriteReclamation.Normale => "text-blue-600",
                            AssuranceApp.Models.PrioriteReclamation.Haute => "text-orange-600 font-medium",
                            AssuranceApp.Models.PrioriteReclamation.Urgente => "text-red-600 font-bold",
                            _ => "text-slate-600"
                        };

                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="whitespace-nowrap px-6 py-4">
                                <div class="font-medium text-bnaNavy">@(string.IsNullOrEmpty(rec.NumeroReclamation) ? $"#{rec.IdReclamation}" : rec.NumeroReclamation)</div>
                                <div class="text-xs text-slate-500 mt-0.5">Permis: @rec.NumeroPermis</div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="font-medium text-slate-900 truncate max-w-xs" title="@rec.Objet">@rec.Objet</div>
                                <div class="text-xs text-slate-500 mt-0.5">Le @rec.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium border @statutClass">
                                    @rec.Statut.ToString()
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-xs @priorityClass">
                                @rec.Priorite.ToString()
                            </td>
                            <td class="px-6 py-4 text-right whitespace-nowrap">
                                <button type="button" class="btn btn-primary px-3 py-1.5 text-xs" onclick="openModal('admin-modal-@rec.IdReclamation')">
                                    Traiter
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* Modals for details and updating status *@
@foreach (var rec in Model)
{
    var statutClass = rec.Statut switch
    {
        AssuranceApp.Models.StatutReclamation.Ouverte => "bg-slate-100 text-slate-700",
        AssuranceApp.Models.StatutReclamation.EnCours => "bg-amber-100 text-amber-800",
        AssuranceApp.Models.StatutReclamation.Resolue => "bg-emerald-100 text-emerald-800",
        AssuranceApp.Models.StatutReclamation.Cloturee => "bg-slate-200 text-slate-800",
        _ => "bg-slate-100 text-slate-700"
    };

    <div id="admin-modal-@rec.IdReclamation" class="fixed inset-0 z-50 hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm transition-opacity" onclick="closeModal('admin-modal-@rec.IdReclamation')"></div>

        <div class="fixed inset-0 z-10 w-screen overflow-y-auto">
            <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
                <div class="relative transform overflow-hidden rounded-2xl bg-white text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-4xl">
                    <div class="bg-white px-4 pb-4 pt-5 sm:p-6 sm:pb-4 flex flex-col lg:flex-row gap-8">
                        
                        <!-- Colonne de gauche : Détails soumis par le client -->
                        <div class="flex-1">
                            <div class="flex items-center gap-3 mb-6">
                                <h3 class="text-xl font-semibold leading-6 text-bnaNavy" id="modal-title">
                                    Dossier @(string.IsNullOrEmpty(rec.NumeroReclamation) ? $"#{rec.IdReclamation}" : rec.NumeroReclamation)
                                </h3>
                                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium @statutClass">@rec.Statut.ToString()</span>
                            </div>
                            
                            <div class="space-y-5">
                                <div>
                                    <h4 class="text-xs font-bold uppercase tracking-wider text-slate-400">Client / Permis</h4>
                                    <p class="mt-1 text-sm font-medium text-slate-900">@rec.NumeroPermis</p>
                                </div>
                                <div>
                                    <h4 class="text-xs font-bold uppercase tracking-wider text-slate-400">Objet</h4>
                                    <p class="mt-1 text-sm font-medium text-slate-900">@rec.Objet</p>
                                </div>
                                <div>
                                    <h4 class="text-xs font-bold uppercase tracking-wider text-slate-400">Description</h4>
                                    <div class="mt-1 text-sm text-slate-700 bg-slate-50 p-3 rounded-lg border border-slate-100 max-h-40 overflow-y-auto">
                                        @rec.Description
                                    </div>
                                </div>
                                
                                @if (!string.IsNullOrEmpty(rec.NumeroPolice) || !string.IsNullOrEmpty(rec.NumeroSinistre))
                                {
                                    <div class="grid grid-cols-2 gap-4">
                                        @if (!string.IsNullOrEmpty(rec.NumeroPolice))
                                        {
                                            <div>
                                                <h4 class="text-xs font-bold uppercase tracking-wider text-slate-400">N° Police</h4>
                                                <p class="mt-1 text-sm font-medium text-slate-900">@rec.NumeroPolice</p>
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(rec.NumeroSinistre))
                                        {
                                            <div>
                                                <h4 class="text-xs font-bold uppercase tracking-wider text-slate-400">N° Sinistre</h4>
                                                <p class="mt-1 text-sm font-medium text-slate-900">@rec.NumeroSinistre</p>
                                            </div>
                                        }
                                    </div>
                                }

                                @if (!string.IsNullOrEmpty(rec.ResultatSouhaite))
                                {
                                    <div>
                                        <h4 class="text-xs font-bold uppercase tracking-wider text-slate-400">Résultat souhaité</h4>
                                        <p class="mt-1 text-sm text-slate-900">@rec.ResultatSouhaite</p>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Colonne de droite : Formulaire d'action -->
                        <div class="flex-1 border-t lg:border-t-0 lg:border-l border-slate-200 pt-6 lg:pt-0 lg:pl-8">
                            <h4 class="text-lg font-semibold text-bnaNavy mb-4">Traitement</h4>
                            
                            <form asp-controller="Reclamation" asp-action="UpdateStatus" method="post" class="space-y-4">
                                <input type="hidden" name="idReclamation" value="@rec.IdReclamation" />
                                
                                <div>
                                    <label class="block text-sm font-medium leading-6 text-slate-900">Statut</label>
                                    <select name="status" class="mt-1 block w-full rounded-md border-0 py-2 pl-3 pr-10 text-slate-900 ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-bnaGreen sm:text-sm sm:leading-6">
                                        @foreach (var val in Enum.GetValues(typeof(AssuranceApp.Models.StatutReclamation)))
                                        {
                                            if (rec.Statut == (AssuranceApp.Models.StatutReclamation)val)
                                            {
                                                <option value="@val" selected>@val</option>
                                            }
                                            else
                                            {
                                                <option value="@val">@val</option>
                                            }
                                        }
                                    </select>
                                </div>

                                <div>
                                    <label class="block text-sm font-medium leading-6 text-slate-900">Commentaire de résolution</label>
                                    <textarea name="commentaireResolution" rows="4" class="mt-1 block w-full rounded-md border-0 py-1.5 text-slate-900 ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-bnaGreen sm:text-sm sm:leading-6" placeholder="Message visible par le client...">@rec.CommentaireResolution</textarea>
                                </div>

                                <div class="pt-4 flex items-center justify-end gap-3">
                                    <button type="button" class="btn btn-ghost" onclick="closeModal('admin-modal-@rec.IdReclamation')">Annuler</button>
                                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                                </div>
                            </form>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        function openModal(id) {
            document.getElementById(id).classList.remove('hidden');
        }
        function closeModal(id) {
            document.getElementById(id).classList.add('hidden');
        }
    </script>
}
