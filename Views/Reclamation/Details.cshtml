@model Reclamation

@{
    ViewData["Title"] = "Reclamation Details";
}

<div class="container py-4">
    <h1 class="h3 mb-3">Reclamation Details</h1>

    <dl class="row">
        <dt class="col-sm-3">Objet</dt>
        <dd class="col-sm-9">@Model.Objet</dd>

        <dt class="col-sm-3">Description</dt>
        <dd class="col-sm-9">@Model.Description</dd>

        <dt class="col-sm-3">Statut</dt>
        <dd class="col-sm-9">@Model.Statut</dd>

        <dt class="col-sm-3">Created At</dt>
        <dd class="col-sm-9">@Model.CreatedAt.ToString("u")</dd>
    </dl>
</div>
