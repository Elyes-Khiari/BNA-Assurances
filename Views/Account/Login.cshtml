@{
    ViewData["Title"] = "Se connecter";
}

<div class="flex min-h-[80vh] items-center justify-center bg-bnaWarm px-4 py-12 sm:px-6 lg:px-8">
    <div class="w-full max-w-md space-y-8 rounded-2xl bg-white p-10 shadow-xl border border-slate-100">
        <div>
            <h2 class="mt-2 text-center text-3xl font-bold tracking-tight text-bnaNavy font-display">
                Connexion
            </h2>
            <p class="mt-3 text-center text-sm text-slate-500">
                Accédez à votre espace client
            </p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="rounded-md bg-red-50 p-4 border border-red-200">
                <div class="flex">
                    <div class="flex-shrink-0">
                        <i data-lucide="alert-circle" class="h-5 w-5 text-red-400"></i>
                    </div>
                    <div class="ml-3">
                        <h3 class="text-sm font-medium text-red-800">Erreur</h3>
                        <div class="mt-2 text-sm text-red-700">
                            <p>@ViewBag.Error</p>
                        </div>
                    </div>
                </div>
            </div>
        }

        <form class="mt-8 space-y-6" asp-action="Login" method="post">
            <div class="space-y-4 rounded-md shadow-sm">
                <div>
                    <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Adresse e-mail</label>
                    <input id="email" name="email" type="email" autocomplete="email" required
                           class="relative block w-full rounded-lg border-0 py-2.5 text-slate-900 ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:z-10 focus:ring-2 focus:ring-inset focus:ring-bnaGreen sm:text-sm sm:leading-6 px-3"
                           placeholder="vous@exemple.com">
                </div>
                <div>
                    <label for="password" class="block text-sm font-medium text-slate-700 mb-1 mt-4">Mot de passe</label>
                    <input id="password" name="password" type="password" autocomplete="current-password" required
                           class="relative block w-full rounded-lg border-0 py-2.5 text-slate-900 ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:z-10 focus:ring-2 focus:ring-inset focus:ring-bnaGreen sm:text-sm sm:leading-6 px-3"
                           placeholder="••••••••">
                </div>
            </div>

            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <input id="remember-me" name="remember-me" type="checkbox"
                           class="h-4 w-4 rounded border-slate-300 text-bnaGreen focus:ring-bnaGreen">
                    <label for="remember-me" class="ml-2 block text-sm text-slate-900">Se souvenir de moi</label>
                </div>

                <div class="text-sm">
                    <a href="#" class="font-medium text-bnaGreen hover:text-bnaDeepGreen transition">Mot de passe oublié ?</a>
                </div>
            </div>

            <div>
                <button type="submit"
                        class="group relative flex w-full justify-center rounded-lg bg-bnaGreen px-3 py-3 text-sm font-semibold text-white hover:bg-bnaDeepGreen focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-bnaGreen transition shadow-md">
                    Se connecter
                </button>
            </div>
        </form>
        
        <p class="mt-8 text-center text-sm text-slate-500">
            Vous n'avez pas de compte ?
            <a asp-controller="Account" asp-action="Signup" class="font-semibold leading-6 text-bnaGreen hover:text-bnaDeepGreen transition">S'inscrire</a>
        </p>
    </div>
</div>
